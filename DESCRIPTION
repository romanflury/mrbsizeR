Package: mrbsizeR
Type: Package
Title: Scale Space Multiresolution Analysis of Random Signals
Version: 1.3.1
Date: 2026-07-05
Authors@R: c(
    person("Thimo", "Schuster", email = "thimo.schuster@gmail.com", role = c("aut")),
